          <button class="btn-social">🇬 Google</button>
          <button class="btn-social">📘 Facebook</button>
        </div>
      </div>
      <div id="authFormSignup" style="display:none">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="fgroup"><label class="flabel">Prénom</label><input class="finput" placeholder="Prénom"></div>
          <div class="fgroup"><label class="flabel">Nom</label><input class="finput" placeholder="Nom"></div>
        </div>
        <div class="fgroup"><label class="flabel">Email</label><input class="finput" type="email" placeholder="email@exemple.com"></div>
        <div class="fgroup"><label class="flabel">Téléphone</label><input class="finput" placeholder="+212 6XX XXX XXX"></div>
        <div class="fgroup"><label class="flabel">Je suis</label>
          <select class="fselect"><option>Étudiant</option><option>Jeune actif</option><option>Propriétaire</option></select>
        </div>
        <div class="fgroup"><label class="flabel">Mot de passe</label><input class="finput" type="password" placeholder="Minimum 8 caractères"></div>
        <button class="btn-auth-submit">Créer mon compte</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ CHAT WIDGET ═══ -->
<div class="chat-widget">
  <div class="chat-panel" id="chatPanel">
    <div class="cp-header">
      <div class="cp-av">🏠</div>
      <div class="cp-info">
        <div class="cp-name">Azul Assistant</div>
        <div class="cp-status"><div style="width:7px;height:7px;border-radius:50%;background:#4ADE80"></div>En ligne · Powered by Claude</div>
      </div>
      <button class="cp-close" onclick="toggleChat()">✕</button>
    </div>
    <div class="cp-messages" id="cpMessages">
      <div class="cp-msg ai"><div class="cp-bubble">Bonjour ! 👋 Je suis Azul Assistant. Décrivez-moi votre projet et je vous trouve les meilleurs logements.<br><br>🎓 Étudiant ? Budget ? Ville ?</div></div>
    </div>
    <div class="cp-input-row">
      <input class="cp-input" id="cpInput" placeholder="Écrire un message…" onkeydown="if(event.key==='Enter')sendChatMsg()">
      <button class="cp-send" onclick="sendChatMsg()">➤</button>
    </div>
  </div>
  <button class="chat-bubble-btn" onclick="toggleChat()">
    💬
    <div class="chat-notif">3</div>
  </button>
</div>

<script>
// ── PAGES
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── SCROLL SMOOTH
function scrollTo(id) {
  setTimeout(() => {
    document.getElementById(id)?.scrollIntoView({behavior:'smooth'});
  }, 100);
}

// ── NAVBAR SCROLL
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
});

// ── SEARCH TAB
function setSearchTab(el) {
  el.closest('.hsc-tabs').querySelectorAll('.hsc-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// ── FILTER TYPE
function setType(el) {
  el.closest('.fb-types').querySelectorAll('.fb-type-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  syncResults();
}

// ── ROOMS
function setRooms(el) {
  el.closest('.fb-rooms-row').querySelectorAll('.fb-room-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  syncResults();
}

// ── RESULTS COUNT
function syncResults() {
  const base = 4800;
  const rand = Math.floor(Math.random() * 300 + 50);
  document.getElementById('resultsCount').textContent = (base - rand).toLocaleString('fr-FR');
}

// ── FAVORITES
function toggleFav(btn) {
  btn.classList.toggle('active');
  btn.textContent = btn.classList.contains('active') ? '❤️' : '🤍';
}

// ── DETAIL MODAL
function openDetail(id) {
  document.getElementById('detailModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeDetail() {
  document.getElementById('detailModal').classList.remove('show');
  document.body.style.overflow = '';
}

// ── GALLERY
function setGallery(thumb, src) {
  document.querySelectorAll('.gthumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
  const main = document.getElementById('galleryMain');
  main.style.opacity = '0';
  setTimeout(() => { main.src = src; main.style.opacity = '1'; }, 180);
}
document.getElementById('galleryMain').style.transition = 'opacity .18s';

// ── AUTH MODAL
function showAuth(tab) {
  document.getElementById('authModal').classList.add('show');
  switchAuthTab(tab);
  document.body.style.overflow = 'hidden';
}
function closeAuth() {
  document.getElementById('authModal').classList.remove('show');
  document.body.style.overflow = '';
}
function switchAuthTab(tab) {
  const isSign = tab === 'signin';
  document.getElementById('authFormSignin').style.display = isSign ? 'block' : 'none';
  document.getElementById('authFormSignup').style.display = isSign ? 'none' : 'block';
  document.getElementById('atab1').classList.toggle('active', isSign);
  document.getElementById('atab2').classList.toggle('active', !isSign);
  document.getElementById('authTitle').textContent = isSign ? 'Connexion' : 'Créer un compte';
  document.getElementById('authSub').textContent = isSign ? 'Bienvenue sur Azul Home' : 'Rejoignez la communauté';
}
document.addEventListener('keydown', e => { if(e.key==='Escape') { closeDetail(); closeAuth(); } });

// ── CHAT WIDGET
let chatOpen = false;
function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('chatPanel').classList.toggle('show', chatOpen);
  document.querySelector('.chat-notif').style.display = chatOpen ? 'none' : 'flex';
  if(chatOpen) document.getElementById('cpInput').focus();
}

const chatReplies = [
  "Très bien ! Laissez-moi chercher les logements disponibles pour votre profil 🔍",
  "J'ai trouvé plusieurs annonces correspondantes ! Voulez-vous que je les affiche ? 🏠",
  "Pour un étudiant à Rabat avec un budget de 2 000 MAD, j'ai 12 logements vérifiés 🎓",
  "Ces logements sont tous proches des universités et disposent du WiFi inclus 📶",
  "Souhaitez-vous contacter directement le propriétaire de l'une de ces annonces ? 💬",
  "Je peux aussi vous aider à trouver des colocataires compatibles ! 🤝",
];
let chatReplyIdx = 0;

function sendChatMsg() {
  const input = document.getElementById('cpInput');
  const msgs = document.getElementById('cpMessages');
  const msg = input.value.trim();
  if(!msg) return;

  // User message
  const userDiv = document.createElement('div');
  userDiv.className = 'cp-msg user';
  userDiv.innerHTML = `<div class="cp-bubble">${msg}</div>`;
  msgs.appendChild(userDiv);
  input.value = '';

  // Typing indicator
  const typingDiv = document.createElement('div');
  typingDiv.className = 'cp-msg ai';
  typingDiv.innerHTML = '<div class="cp-typing"><div class="cp-dot"></div><div class="cp-dot"></div><div class="cp-dot"></div></div>';
  msgs.appendChild(typingDiv);
  msgs.scrollTop = msgs.scrollHeight;

  setTimeout(() => {
    typingDiv.remove();
    const aiDiv = document.createElement('div');
    aiDiv.className = 'cp-msg ai';
    const reply = chatReplies[chatReplyIdx % chatReplies.length];
    chatReplyIdx++;
    aiDiv.innerHTML = `<div class="cp-bubble">${reply}</div>`;
    msgs.appendChild(aiDiv);
    msgs.scrollTop = msgs.scrollHeight;
  }, 1200);
}

// ── PACKAGE SELECTION
function selectPkg(el) {
  document.querySelectorAll('.package-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

// ── SUBMIT ANNONCE
function submitAnnonce() {
  alert('✅ Votre annonce a été soumise avec succès !\n\nNotre équipe la vérifiera dans les 24h.\nVous recevrez une confirmation par email et SMS.');
}

// ── SCROLL REVEAL
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('on'); });
}, {threshold: 0.08});
document.querySelectorAll('.reveal, .reveal-l').forEach(el => obs.observe(el));

// ── COUNTER ANIMATION
function animCounter(el) {
  const target = parseInt(el.dataset.target);
  const suffix = el.dataset.suffix || '';
  const dur = 1800, step = 16;
  const inc = target / (dur / step);
  let cur = 0;
  const t = setInterval(() => {
    cur += inc;
    if(cur >= target) { cur = target; clearInterval(t); }
    el.textContent = Math.floor(cur).toLocaleString('fr-FR') + suffix;
  }, step);
}
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(e.isIntersecting) {
      document.querySelectorAll('.hs-num[data-target]').forEach(animCounter);
      counterObs.disconnect();
    }
  });
}, {threshold: 0.4});
const heroStats = document.querySelector('.hero-stats');
if(heroStats) counterObs.observe(heroStats);

// ── TOGGLE AMENITY CHECKS visual
document.querySelectorAll('.amen-check').forEach(label => {
  label.addEventListener('change', () => {
    label.style.borderColor = label.querySelector('input').checked ? 'var(--gold)' : 'var(--border)';
    label.style.background = label.querySelector('input').checked ? '#FFFDF5' : 'white';
    label.style.color = label.querySelector('input').checked ? 'var(--gold-dk)' : 'var(--ink3)';
  });
  // Init
  if(label.querySelector('input').checked) {
    label.style.borderColor = 'var(--gold)';
    label.style.background = '#FFFDF5';
    label.style.color = 'var(--gold-dk)';
  }
});

// Set today's date min for booking
const dateInput = document.getElementById('moveInDate');
if(dateInput) {
  const today = new Date().toISOString().split('T')[0];
  dateInput.min = today;
  dateInput.value = today;
}
</script>
</body>
</html>
